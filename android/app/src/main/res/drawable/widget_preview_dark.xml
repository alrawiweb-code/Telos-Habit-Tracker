<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#121212" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    
    <!-- Header simulation -->
    <item android:top="20dp" android:left="20dp" android:right="20dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <size android:height="50dp" />
        </shape>
    </item>
    
    <!-- Title block simulation -->
    <item android:top="25dp" android:left="20dp" android:right="120dp" android:bottom="140dp">
        <shape android:shape="rectangle">
            <solid android:color="#F1F1F1" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    
    <!-- Item 1 simulation -->
    <item android:top="110dp" android:left="20dp" android:right="180dp" android:bottom="50dp">
        <shape android:shape="rectangle">
            <solid android:color="#070707" />
            <corners android:radius="100dp" />
        </shape>
    </item>
    
    <!-- Item 2 simulation -->
    <item android:top="110dp" android:left="180dp" android:right="20dp" android:bottom="50dp">
        <shape android:shape="rectangle">
            <solid android:color="#070707" />
            <corners android:radius="100dp" />
        </shape>
    </item>
    
</layer-list>
