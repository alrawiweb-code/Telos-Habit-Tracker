<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="10dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="@drawable/widget_item_bg">

    <!-- Left: Circular letter avatar -->
    <FrameLayout
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="10dp">

        <ImageView
            android:id="@+id/widget_item_icon_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/widget_icon_bg"
            android:scaleType="fitXY" />

        <TextView
            android:id="@+id/widget_item_icon_letter"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="T"
            android:textSize="17sp"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/widget_text_primary" />
    </FrameLayout>

    <!-- Center: Task name -->
    <TextView
        android:id="@+id/widget_item_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:maxLines="1"
        android:ellipsize="end"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/widget_text_primary" />

    <!-- Right: Status circle -->
    <FrameLayout
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="8dp">

        <ImageView
            android:id="@+id/widget_item_check_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/widget_circle_empty"
            android:scaleType="fitXY" />

        <TextView
            android:id="@+id/widget_item_check_mark"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="✓"
            android:textSize="15sp"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/widget_text_primary"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
