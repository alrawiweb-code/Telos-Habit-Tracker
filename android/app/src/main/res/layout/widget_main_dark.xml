<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background_dark"
    android:padding="20dp"
    android:clipToPadding="false">

    <!-- ═══ HEADER ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <!-- Left: Title + Subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tasks"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/widget_dark_text_primary" />

            <TextView
                android:id="@+id/widget_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good progress today"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/widget_dark_text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Right: Progress Ring -->
        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="12dp">

            <ProgressBar
                android:id="@+id/widget_progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="false"
                android:max="100"
                android:progress="50"
                android:progressDrawable="@drawable/circular_progress_bar_dark" />

            <TextView
                android:id="@+id/widget_progress_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="0/0"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold"
                android:textColor="@color/widget_dark_text_primary" />
        </FrameLayout>
    </LinearLayout>

    <!-- ═══ ACTION BUTTONS ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="14dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btn_add_intention"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="＋ New Intention"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:textColor="@color/widget_dark_text_primary"
            android:background="@drawable/widget_btn_bg_dark"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_add_journal"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="＋ Journal Entry"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:textColor="@color/widget_dark_text_primary"
            android:background="@drawable/widget_btn_bg_dark"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- ═══ TASK GRID ═══ -->
    <GridView
        android:id="@+id/widget_list_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:numColumns="2"
        android:horizontalSpacing="10dp"
        android:verticalSpacing="10dp"
        android:stretchMode="columnWidth"
        android:gravity="center" />

    <TextView
        android:id="@+id/widget_empty_text"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="No tasks for today.\nTap + to add one."
        android:textSize="14sp"
        android:textColor="@color/widget_dark_text_secondary"
        android:visibility="gone"/>

</LinearLayout>
